<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Q-PORT | 나의 탐구 항해일지</title>
<meta name="description" content="나만의 웹 작품, 독서 기록, 자주 가는 사이트를 모아둔 탐험가의 여권">
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧭</text></svg>">
<style>
/* =========================================================================
   QPORT — 디자인 시스템
   컨셉: "나만의 항구에서 세상으로 출항하는 탐험가의 여권 & 항해일지"
   ⚠️ 이 파일은 디자인 담당입니다. 학생은 보통 건드릴 필요 없어요.
   ========================================================================= */

@import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap');

:root {
  /* --- 색: 해질녘 항구 팔레트 --- */
  --ink:      #14293B;   /* 깊은 밤바다 네이비 (기본 텍스트/헤더) */
  --paper:    #F6F1E3;   /* 오래된 지도 종이 (배경) */
  --tide:     #2C7A7B;   /* 잔잔한 바닷물 (보조 강조) */
  --coral:    #E76F51;   /* 노을/부표 (메인 강조·활성 탭) */
  --brass:    #C9922B;   /* 놋쇠 나침반 (뱃지·스탬프) */
  --mist:     #E4E9DE;   /* 옅은 물안개 (카드 배경) */
  --ink-soft: #4A5D6B;   /* 보조 텍스트 */

  --font-display: "Fraunces", serif;
  --font-body: "Inter", sans-serif;
  --font-stamp: "IBM Plex Mono", monospace;

  --radius: 14px;
  --shadow: 0 6px 18px rgba(20, 41, 59, 0.12);
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  font-family: var(--font-body);
  background: var(--paper);
  color: var(--ink);
  line-height: 1.6;
}

a { color: inherit; }

button {
  font-family: inherit;
  cursor: pointer;
}

/* ---------------------------------------------------------------------
   헤더 — 항구 스카이라인 + 여권 카드
   --------------------------------------------------------------------- */
.harbor-header {
  position: relative;
  background: linear-gradient(180deg, var(--ink) 0%, #1C3B52 70%, var(--tide) 100%);
  padding: 40px 20px 90px;
  overflow: hidden;
}

.harbor-header svg.skyline {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: auto;
  opacity: 0.35;
}

.passport-card {
  position: relative;
  z-index: 2;
  max-width: 680px;
  margin: 0 auto;
  background: var(--paper);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 28px 28px 24px;
  display: flex;
  gap: 22px;
  align-items: center;
  border: 1px solid rgba(20,41,59,0.08);
}

.passport-avatar {
  flex: 0 0 auto;
  width: 84px;
  height: 84px;
  border-radius: 50%;
  background: var(--mist);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42px;
  border: 3px dashed var(--brass);
}

.passport-info .label {
  font-family: var(--font-stamp);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--tide);
  margin: 0 0 2px;
}

.passport-info h1 {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(24px, 4vw, 32px);
  margin: 0 0 4px;
  color: var(--ink);
}

.passport-info .nickname {
  font-family: var(--font-display);
  font-style: italic;
  color: var(--coral);
  font-weight: 600;
}

.passport-meta {
  margin-top: 8px;
  font-size: 13px;
  color: var(--ink-soft);
}

.dream-tags {
  margin-top: 10px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.dream-tag {
  font-size: 12px;
  font-family: var(--font-stamp);
  background: var(--mist);
  border: 1px solid rgba(20,41,59,0.15);
  padding: 4px 10px;
  border-radius: 999px;
  color: var(--ink);
}

/* ---------------------------------------------------------------------
   내비게이션 — 스탬프 탭 (시그니처 요소)
   --------------------------------------------------------------------- */
.stamp-nav {
  max-width: 780px;
  margin: -46px auto 0;
  position: relative;
  z-index: 3;
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
  padding: 0 16px;
}

.stamp-tab {
  background: var(--paper);
  border: 2px dashed var(--ink-soft);
  border-radius: 50%;
  width: 84px;
  height: 84px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  transform: rotate(-4deg);
  transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
  font-size: 11px;
  font-family: var(--font-stamp);
  color: var(--ink);
  box-shadow: var(--shadow);
}

.stamp-tab:nth-child(even) { transform: rotate(3deg); }

.stamp-tab .icon { font-size: 22px; }

.stamp-tab:hover { transform: rotate(0deg) scale(1.05); }

.stamp-tab.active {
  background: var(--coral);
  border-style: solid;
  border-color: var(--coral);
  color: #fff;
  transform: rotate(0deg) scale(1.08);
}

.stamp-tab:focus-visible {
  outline: 3px solid var(--tide);
  outline-offset: 3px;
}

/* ---------------------------------------------------------------------
   본문 레이아웃
   --------------------------------------------------------------------- */
main {
  max-width: 900px;
  margin: 0 auto;
  padding: 56px 20px 80px;
}

.section { display: none; animation: fadeIn 0.25s ease; }
.section.active { display: block; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(22px, 3.4vw, 30px);
  font-weight: 700;
  margin: 0 0 6px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.section-sub {
  color: var(--ink-soft);
  margin: 0 0 28px;
  font-size: 14px;
}

/* --- 통계 요약 (나의 항구) --- */
.stat-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 14px;
  margin: 24px 0 8px;
}

.stat-card {
  background: var(--ink);
  color: var(--paper);
  border-radius: var(--radius);
  padding: 18px;
  text-align: center;
}

.stat-card .num {
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 700;
  color: var(--brass);
  display: block;
}

.stat-card .cap {
  font-size: 12px;
  color: var(--mist);
  font-family: var(--font-stamp);
}

.dream-note {
  margin-top: 20px;
  padding: 16px 18px;
  background: var(--mist);
  border-left: 4px solid var(--coral);
  border-radius: 8px;
  font-size: 14px;
}

/* --- 서브탭 (작품창고 / 도구상자) --- */
.subtabs {
  display: flex;
  gap: 8px;
  margin-bottom: 20px;
}

.subtab-btn {
  border: 1px solid var(--ink);
  background: transparent;
  padding: 6px 16px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 600;
}

.subtab-btn.active {
  background: var(--ink);
  color: var(--paper);
}

/* --- 카드 그리드 (작품 / 링크) --- */
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 16px;
}

.work-card {
  background: #fff;
  border: 1px solid rgba(20,41,59,0.1);
  border-radius: var(--radius);
  padding: 18px;
  box-shadow: var(--shadow);
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.work-card h3 {
  font-family: var(--font-display);
  margin: 0;
  font-size: 18px;
}

.badge-row { display: flex; gap: 6px; flex-wrap: wrap; }

.badge {
  font-size: 11px;
  font-family: var(--font-stamp);
  background: var(--mist);
  padding: 3px 8px;
  border-radius: 6px;
  color: var(--ink);
}

.work-card .desc { font-size: 13px; color: var(--ink-soft); margin: 0; }
.work-card .note {
  font-size: 12.5px;
  color: var(--tide);
  font-style: italic;
  margin: 0;
}

.work-card .open-link {
  margin-top: auto;
  align-self: flex-start;
  font-size: 13px;
  font-weight: 600;
  color: var(--coral);
  text-decoration: none;
  border-bottom: 1px solid var(--coral);
}

/* --- 항해일지 (독서기록) --- */
.log-semester {
  font-family: var(--font-stamp);
  font-size: 13px;
  color: var(--tide);
  border-bottom: 2px solid var(--tide);
  display: inline-block;
  padding-bottom: 2px;
  margin: 28px 0 12px;
}

.log-entry {
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: 16px;
  background: #fff;
  border-radius: var(--radius);
  padding: 16px 18px;
  margin-bottom: 12px;
  box-shadow: var(--shadow);
}

.log-stamp {
  width: 76px;
  height: 76px;
  border: 2px dashed var(--brass);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-stamp);
  font-size: 10px;
  text-align: center;
  color: var(--brass);
  transform: rotate(-6deg);
  line-height: 1.3;
}

.log-entry h4 { margin: 0 0 2px; font-family: var(--font-display); font-size: 17px; }
.log-entry .author { font-size: 13px; color: var(--ink-soft); margin: 0 0 6px; }
.log-entry .impact { font-size: 13.5px; margin: 0 0 4px; }
.log-entry .extended {
  font-size: 12.5px;
  color: var(--coral);
  font-weight: 600;
}

.recommend-box {
  margin-top: 36px;
  background: var(--mist);
  border-radius: var(--radius);
  padding: 20px;
}

.recommend-box h3 {
  font-family: var(--font-display);
  font-size: 16px;
  margin: 0 0 12px;
}

.recommend-group { margin-bottom: 10px; font-size: 13.5px; }
.recommend-group b { color: var(--tide); }

.disclaimer {
  font-size: 12px;
  color: var(--ink-soft);
  margin-top: 10px;
}

/* --- 나침반 (링크) --- */
.link-card {
  background: #fff;
  border: 1px solid rgba(20,41,59,0.1);
  border-radius: 999px;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  color: var(--ink);
  font-weight: 600;
  box-shadow: var(--shadow);
  transition: transform 0.15s ease;
}

.link-card:hover { transform: translateY(-2px) rotate(-1deg); }
.link-card .emoji { font-size: 22px; }

/* --- 도구상자 --- */
.tool-card {
  background: #fff;
  border-radius: var(--radius);
  padding: 16px 18px;
  box-shadow: var(--shadow);
  margin-bottom: 12px;
}

.tool-card .word {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  color: var(--tide);
}

.tool-card .meaning { font-size: 13.5px; color: var(--ink-soft); }
.tool-card .example { font-size: 13px; font-style: italic; margin-top: 4px; }

.tool-card .formula {
  font-family: var(--font-stamp);
  font-size: 20px;
  color: var(--coral);
  font-weight: 600;
}

/* --- 검색창 (도구상자) --- */
.tool-search {
  width: 100%;
  max-width: 320px;
  padding: 10px 14px;
  border: 1px solid var(--ink-soft);
  border-radius: 999px;
  font-size: 13px;
  margin-bottom: 18px;
  font-family: var(--font-body);
}

.tool-search:focus-visible { outline: 3px solid var(--tide); }

/* ---------------------------------------------------------------------
   푸터
   --------------------------------------------------------------------- */
footer {
  text-align: center;
  padding: 24px 16px 40px;
  font-size: 12px;
  color: var(--ink-soft);
  font-family: var(--font-stamp);
}

/* ---------------------------------------------------------------------
   반응형 + 접근성
   --------------------------------------------------------------------- */
@media (max-width: 560px) {
  .passport-card { flex-direction: column; text-align: center; }
  .stamp-tab { width: 70px; height: 70px; }
  .log-entry { grid-template-columns: 1fr; }
  .log-stamp { justify-self: center; }
}

@media (prefers-reduced-motion: reduce) {
  * { animation: none !important; transition: none !important; }
}

</style>
</head>
<body>

  <header class="harbor-header">
    <svg class="skyline" viewBox="0 0 1200 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="40" y="90" width="30" height="110" fill="#F6F1E3"/>
      <rect x="90" y="60" width="24" height="140" fill="#F6F1E3"/>
      <polygon points="102,40 90,60 114,60" fill="#F6F1E3"/>
      <rect x="160" y="110" width="40" height="90" fill="#F6F1E3"/>
      <rect x="900" y="70" width="26" height="130" fill="#F6F1E3"/>
      <rect x="950" y="100" width="34" height="100" fill="#F6F1E3"/>
      <polygon points="967,70 950,100 984,100" fill="#F6F1E3"/>
      <rect x="1050" y="50" width="20" height="150" fill="#F6F1E3"/>
      <circle cx="1060" cy="35" r="8" fill="#F6F1E3"/>
      <path d="M0,180 Q300,150 600,180 T1200,180 V200 H0 Z" fill="#F6F1E3" opacity="0.5"/>
    </svg>

    <div class="passport-card">
      <div class="passport-avatar" id="passport-avatar">🧭</div>
      <div class="passport-info">
        <p class="label">Q-PORT · 탐험가 여권</p>
        <h1 id="passport-name">이름</h1>
        <p class="nickname" id="passport-nickname"></p>
        <p class="passport-meta" id="passport-meta"></p>
        <div class="dream-tags" id="dream-tags"></div>
      </div>
    </div>
  </header>

  <nav class="stamp-nav">
    <button class="stamp-tab active" data-target="sec-home"><span class="icon">🛳️</span>나의 항구</button>
    <button class="stamp-tab" data-target="sec-works"><span class="icon">🧰</span>작품 창고</button>
    <button class="stamp-tab" data-target="sec-reading"><span class="icon">📖</span>항해일지</button>
    <button class="stamp-tab" data-target="sec-links"><span class="icon">🧭</span>나침반</button>
    <button class="stamp-tab" data-target="sec-tools"><span class="icon">🎒</span>도구상자</button>
  </nav>

  <main>

    <!-- 1. 나의 항구 -->
    <section id="sec-home" class="section active">
      <h2 class="section-title">🛳️ 나의 항구</h2>
      <p class="section-sub">탐험가의 기본 정보와 지금까지의 항해 기록 요약이에요.</p>

      <div class="stat-row">
        <div class="stat-card"><span class="num" id="stat-works">0</span><span class="cap">만든 작품</span></div>
        <div class="stat-card"><span class="num" id="stat-books">0</span><span class="cap">읽은 책</span></div>
        <div class="stat-card"><span class="num" id="stat-links">0</span><span class="cap">즐겨찾는 곳</span></div>
      </div>

      <div class="dream-note">
        <strong>🎯 나의 꿈 노트</strong>
        <p id="dream-note" style="margin:6px 0 0;"></p>
      </div>
    </section>

    <!-- 2. 작품 창고 -->
    <section id="sec-works" class="section">
      <h2 class="section-title">🧰 작품 창고</h2>
      <p class="section-sub">내가 만든 웹 작품들을 교과 관련 / 교과 외로 모아봤어요.</p>

      <div class="subtabs" id="works-subtabs">
        <button class="subtab-btn active" data-filter="전체">전체</button>
        <button class="subtab-btn" data-filter="교과">교과 관련</button>
        <button class="subtab-btn" data-filter="교과외">교과 외</button>
      </div>

      <div class="card-grid" id="works-grid"></div>
    </section>

    <!-- 3. 항해일지 (독서기록) -->
    <section id="sec-reading" class="section">
      <h2 class="section-title">📖 탐구 항해일지</h2>
      <p class="section-sub">학기별 독서 기록이에요. 도서명·저자를 기록해두면 학교 독서활동 기록에도 활용할 수 있어요.</p>

      <div id="reading-log-wrap"></div>

      <div class="recommend-box">
        <h3>📚 학년별 추천도서 (참고용)</h3>
        <div id="recommend-list"></div>
        <p class="disclaimer">※ 위 목록은 예시입니다. 실제 도서는 학교·교육부·시도교육청 추천도서 목록이나 도서관정보나루 등에서 학년에 맞게 확인해 data.js를 바꿔서 사용하세요.</p>
      </div>
    </section>

    <!-- 4. 나침반 (링크) -->
    <section id="sec-links" class="section">
      <h2 class="section-title">🧭 나침반</h2>
      <p class="section-sub">자주 방문하는 사이트로 바로 이동해요.</p>
      <div class="card-grid" id="links-grid"></div>
    </section>

    <!-- 5. 도구상자 -->
    <section id="sec-tools" class="section">
      <h2 class="section-title">🎒 탐구 도구상자</h2>
      <p class="section-sub">영어 단어와 수학 공식을 검색해서 찾아봐요.</p>

      <h3 style="font-family:var(--font-display); font-size:16px;">🔤 영어 단어장</h3>
      <input class="tool-search" id="word-search" type="text" placeholder="단어나 뜻으로 검색해보세요">
      <div id="wordbook-wrap" style="margin-bottom:32px;"></div>

      <h3 style="font-family:var(--font-display); font-size:16px;">📐 수학 공식노트</h3>
      <input class="tool-search" id="math-search" type="text" placeholder="공식 이름으로 검색해보세요">
      <div id="mathnotes-wrap"></div>
    </section>

  </main>

  <footer>Q-PORT · Quvia-Lab 학생 포트폴리오 템플릿</footer>

  <!-- ======================================================================
       ✏️✏️✏️  여기서부터 "내 정보 수정하는 곳" 시작! ✏️✏️✏️
       (Ctrl+F 로 "여기서부터"를 검색하면 이 위치로 바로 올 수 있어요)
       ====================================================================== -->
  <script>
/* =========================================================================
   ✏️  이 <script> 안의 내용만 고치면 홈페이지 내용이 바뀝니다!
   -------------------------------------------------------------------------
   ⚠️ 이 <script> 밖의 코드(위/아래)는 건드리지 않아도 됩니다.
   ⚠️ 이 파일은 자바스크립트라서 // 뒤에 설명(주석)을 자유롭게 써도 안전해요.
   ⚠️ 항목을 추가할 땐 { ... } 덩어리를 통째로 복사해서 붙여넣고 내용만 바꾸세요.
   ⚠️ 쉼표(,) 하나만 빠뜨려도 화면이 안 나올 수 있어요. 마지막 항목에는
      쉼표를 넣지 않는 걸 헷갈리면, 그냥 매 줄 끝에 쉼표를 붙여도 괜찮습니다.
   ========================================================================= */

window.QPORT_DATA = {

  /* ---------------------------------------------------------------------
     1. 나의 항구 — 프로필
     --------------------------------------------------------------------- */
  profile: {
