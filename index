  <!-- ======================================================================
       ✅ 여기까지가 "내 정보 수정하는 곳" 끝!
       이 아래 코드는 화면을 그려주는 부분이라 평소엔 건드릴 필요 없어요.
       ====================================================================== -->

  <script>
/* =========================================================================
   QPORT — 렌더링 스크립트 (화면을 그려주는 코드, 평소엔 건드리지 않아도 됨)
   ========================================================================= */

const D = window.QPORT_DATA;

/* ---------- 유틸 ---------- */
function el(html) {
  const t = document.createElement("template");
  t.innerHTML = html.trim();
  return t.content.firstElementChild;
}

function daysSince(dateStr) {
  const start = new Date(dateStr);
  const diff = Math.floor((Date.now() - start.getTime()) / (1000 * 60 * 60 * 24));
  return Number.isFinite(diff) && diff >= 0 ? diff : 0;
}

/* ---------- 1. 프로필 ---------- */
function renderProfile() {
  const p = D.profile;
  document.getElementById("passport-avatar").textContent = p.avatarEmoji || "🧭";
  document.getElementById("passport-name").textContent = p.name || "탐험가";
  document.getElementById("passport-nickname").textContent = p.nickname ? `“${p.nickname}”` : "";
  document.getElementById("passport-meta").textContent =
    `${p.school || ""} · 탐구 시작 ${p.startDate || "-"} (D+${daysSince(p.startDate)})`;

  const tagWrap = document.getElementById("dream-tags");
  tagWrap.innerHTML = "";
  (p.dreams || []).forEach(d => tagWrap.appendChild(el(`<span class="dream-tag">🎯 ${d}</span>`)));

  document.getElementById("dream-note").textContent = p.dreamNote || "";

  // 성장 요약 통계
  document.getElementById("stat-works").textContent = (D.works || []).length;
  document.getElementById("stat-books").textContent = (D.readingLog || []).length;
  document.getElementById("stat-links").textContent = (D.links || []).length;
}

/* ---------- 2. 작품 창고 ---------- */
function renderWorks(filter = "전체") {
  const grid = document.getElementById("works-grid");
  grid.innerHTML = "";
  const list = (D.works || []).filter(w => filter === "전체" || w.category === filter);

  if (list.length === 0) {
    grid.appendChild(el(`<p class="section-sub">아직 등록된 작품이 없어요. data.js 의 works 배열에 추가해보세요!</p>`));
    return;
  }

  list.forEach(w => {
    const badges = (w.skills || []).map(s => `<span class="badge">${s}</span>`).join("");
    grid.appendChild(el(`
      <div class="work-card">
        <h3>${w.title}</h3>
        <div class="badge-row"><span class="badge">${w.subject || w.category}</span>${badges}</div>
        <p class="desc">${w.desc || ""}</p>
        ${w.note ? `<p class="note">💬 ${w.note}</p>` : ""}
        ${w.url ? `<a class="open-link" href="${w.url}" target="_blank" rel="noopener">작품 열어보기 →</a>` : ""}
      </div>
    `));
  });
}

/* ---------- 3. 항해일지 (독서기록) ---------- */
function renderReadingLog() {
  const wrap = document.getElementById("reading-log-wrap");
  wrap.innerHTML = "";
  const bySemester = {};
  (D.readingLog || []).forEach(r => {
    bySemester[r.semester] = bySemester[r.semester] || [];
    bySemester[r.semester].push(r);
  });

  Object.keys(bySemester).sort().forEach(sem => {
    wrap.appendChild(el(`<div class="log-semester">📖 ${sem}</div>`));
    bySemester[sem].forEach(r => {
      wrap.appendChild(el(`
        <div class="log-entry">
          <div class="log-stamp">${r.subjectLink || "자유"}<br/>독서</div>
          <div>
            <h4>${r.title}</h4>
            <p class="author">${r.author ? `저자: ${r.author}` : ""} ${r.period ? `· ${r.period}` : ""}</p>
            <p class="impact">${r.impact || ""}</p>
            ${r.extendedActivity ? `<p class="extended">🔗 확장 활동: ${r.extendedActivity}</p>` : ""}
          </div>
        </div>
      `));
    });
  });

  // 추천도서 참고 목록
  const recBox = document.getElementById("recommend-list");
  recBox.innerHTML = "";
  const rec = D.recommendedBooks || {};
  Object.keys(rec).forEach(grade => {
    recBox.appendChild(el(`<div class="recommend-group"><b>${grade}</b> — ${rec[grade].join(", ")}</div>`));
  });
}

/* ---------- 4. 나침반 (링크) ---------- */
function renderLinks() {
  const grid = document.getElementById("links-grid");
  grid.innerHTML = "";
  (D.links || []).forEach(l => {
    grid.appendChild(el(`
      <a class="link-card" href="${l.url}" target="_blank" rel="noopener">
        <span class="emoji">${l.icon || "🔗"}</span> ${l.title}
      </a>
    `));
  });
}

/* ---------- 5. 도구상자 ---------- */
function renderWordbook(query = "") {
  const wrap = document.getElementById("wordbook-wrap");
  wrap.innerHTML = "";
  const q = query.trim().toLowerCase();
  const list = (D.wordbook || []).filter(w =>
    !q || w.word.toLowerCase().includes(q) || w.meaning.includes(q)
  );
  list.forEach(w => {
    wrap.appendChild(el(`
      <div class="tool-card">
        <div class="word">${w.word}</div>
        <div class="meaning">${w.meaning}</div>
        ${w.example ? `<div class="example">"${w.example}"</div>` : ""}
      </div>
    `));
  });
}

function renderMathNotes(query = "") {
  const wrap = document.getElementById("mathnotes-wrap");
  wrap.innerHTML = "";
  const q = query.trim().toLowerCase();
  const list = (D.mathNotes || []).filter(m =>
    !q || m.name.toLowerCase().includes(q) || (m.when || "").includes(q)
  );
  list.forEach(m => {
    wrap.appendChild(el(`
      <div class="tool-card">
        <div class="formula">${m.formula}</div>
        <div class="meaning"><b>${m.name}</b> — ${m.when || ""}</div>
        ${m.relatedWork ? `<div class="example">🔗 관련 작품: ${m.relatedWork}</div>` : ""}
      </div>
    `));
  });
}

/* ---------- 탭 전환 ---------- */
function switchSection(target) {
  document.querySelectorAll(".section").forEach(s => s.classList.toggle("active", s.id === target));
  document.querySelectorAll(".stamp-tab").forEach(b => b.classList.toggle("active", b.dataset.target === target));
}

function switchSubtab(groupSelector, target, renderFn) {
  document.querySelectorAll(`${groupSelector} .subtab-btn`).forEach(b =>
    b.classList.toggle("active", b.dataset.filter === target)
  );
  renderFn(target);
}

/* ---------- 초기화 ---------- */
document.addEventListener("DOMContentLoaded", () => {
  renderProfile();
  renderWorks();
  renderReadingLog();
  renderLinks();
  renderWordbook();
  renderMathNotes();

  document.querySelectorAll(".stamp-tab").forEach(btn => {
    btn.addEventListener("click", () => switchSection(btn.dataset.target));
  });

  document.querySelectorAll("#works-subtabs .subtab-btn").forEach(btn => {
    btn.addEventListener("click", () => switchSubtab("#works-subtabs", btn.dataset.filter, renderWorks));
  });

  document.getElementById("word-search").addEventListener("input", e => renderWordbook(e.target.value));
  document.getElementById("math-search").addEventListener("input", e => renderMathNotes(e.target.value));
});

</script>
